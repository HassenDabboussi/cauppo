# Template for envs/.env.development
# Copy to envs/.env.development and fill in real values before running docker compose.
# This file is safe to commit - it contains only structure, no real secrets.

# === COMMON ===
CAUPPO_ENV=development
NODE_ENV=development
CAUPPO_TRACE_HEADER=x-trace-id

# === POSTGRES ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === REDIS ===
REDIS_URL=redis://:cauppo_redis@redis:6379/0

# === RABBITMQ ===
RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
RABBITMQ_DEFAULT_USER=cauppo
RABBITMQ_DEFAULT_PASS=cauppo
RABBITMQ_DEFAULT_VHOST=/cauppo

# === ZITADEL ===
ZITADEL_ISSUER=http://zitadel:8080
ZITADEL_ISSUER_URL=http://zitadel:8080
ZITADEL_DOMAIN=zitadel
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/zitadel?sslmode=disable
ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys

# === TRAEFIK ===
# No dedicated env keys in envs/.env.development.
# Traefik is configured via docker-compose.yml, docker-compose.infra.yml, and traefik/dynamic.yml.

# === MINIO ===
# No dedicated env keys in envs/.env.development.
# MinIO local-dev credentials and bucket bootstrap are configured in docker-compose.infra.yml.

# === MAILPIT ===
# No dedicated env keys in envs/.env.development.
# Mailpit local-dev auth is configured in docker-compose.infra.yml.

# === USER SERVICE ===
USER_SERVICE_PORT=3001
USER_SERVICE_DATABASE_URL=postgresql://cauppo_user:cauppo_user@postgres:5432/cauppo_users
USER_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
USER_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
USER_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
USER_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
USER_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
USER_SERVICE_ZITADEL_AUDIENCE=user-service
USER_SERVICE_JWT_AUDIENCE=user-service
USER_SERVICE_ZITADEL_CLIENT_ID=dev-user-service-client
USER_SERVICE_ZITADEL_CLIENT_SECRET=dev-secret
USER_SERVICE_RESEND_API_KEY=re_dev_placeholder
USER_SERVICE_RESEND_FROM_EMAIL=noreply@cauppo.local
USER_SERVICE_R2_ENDPOINT=http://minio:9000
USER_SERVICE_R2_ACCOUNT_ID=dev
USER_SERVICE_R2_BUCKET_AVATARS=cauppo-avatars
USER_SERVICE_R2_BUCKET_RESTAURANTS=cauppo-restaurants
USER_SERVICE_R2_BUCKET_NAME=cauppo-assets
USER_SERVICE_R2_ACCESS_KEY_ID=minioadmin
USER_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin
USER_SERVICE_R2_PUBLIC_URL=http://localhost:9000/cauppo-assets
USER_SERVICE_SMTP_HOST=mailpit
USER_SERVICE_SMTP_PORT=1025
USER_SERVICE_SMTP_SECURE=false
USER_SERVICE_KONNECT_API_KEY=dev-placeholder
USER_SERVICE_KONNECT_WEBHOOK_SECRET=dev-placeholder
USER_SERVICE_CAUPPO_PUBLIC_APP_URL=http://localhost:3000

# === FEEDBACK SERVICE ===
FEEDBACK_SERVICE_PORT=3002
FEEDBACK_SERVICE_DATABASE_URL=postgresql://cauppo_feedback:cauppo_feedback@postgres:5432/cauppo_feedback
FEEDBACK_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
FEEDBACK_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
FEEDBACK_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
FEEDBACK_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
FEEDBACK_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
FEEDBACK_SERVICE_ZITADEL_AUDIENCE=feedback-service
FEEDBACK_SERVICE_JWT_AUDIENCE=feedback-service
FEEDBACK_SERVICE_ZITADEL_CLIENT_ID=dev-feedback-client
FEEDBACK_SERVICE_ORDER_SERVICE_INTERNAL_URL=http://order-service:8082

# === MENU SERVICE ===
MENU_SERVICE_PORT=8081
MENU_SERVICE_DATABASE_URL=postgresql://cauppo_menu:cauppo_menu@postgres:5432/cauppo_menu
MENU_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
MENU_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
MENU_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
MENU_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
MENU_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
MENU_SERVICE_ZITADEL_AUDIENCE=menu-service
MENU_SERVICE_JWT_AUDIENCE=menu-service
MENU_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
MENU_SERVICE_R2_ENDPOINT=http://minio:9000
MENU_SERVICE_R2_BUCKET_MENU_ITEMS=cauppo-menu-items
MENU_SERVICE_R2_BUCKET_QR=cauppo-qr
MENU_SERVICE_R2_ACCESS_KEY_ID=minioadmin
MENU_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin

# === ORDER SERVICE ===
ORDER_SERVICE_PORT=8082
ORDER_SERVICE_DATABASE_URL=postgresql://cauppo_order:cauppo_order@postgres:5432/cauppo_orders
ORDER_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
ORDER_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
ORDER_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
ORDER_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
ORDER_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
ORDER_SERVICE_ZITADEL_AUDIENCE=order-service
ORDER_SERVICE_JWT_AUDIENCE=order-service
ORDER_SERVICE_MENU_SERVICE_INTERNAL_URL=http://menu-service:8081
ORDER_SERVICE_ORDER_IDEMPOTENCY_TTL_SECONDS=300
ORDER_SERVICE_TABLE_SESSION_LOCK_TTL_SECONDS=30

# === ANALYTICS SERVICE ===
ANALYTICS_SERVICE_PORT=8083
ANALYTICS_SERVICE_DATABASE_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics
ANALYTICS_SERVICE_ANALYTICS_READ_REPLICA_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics_read
ANALYTICS_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
ANALYTICS_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
ANALYTICS_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
ANALYTICS_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
ANALYTICS_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
ANALYTICS_SERVICE_ZITADEL_AUDIENCE=cauppo-api
ANALYTICS_SERVICE_JWT_AUDIENCE=cauppo-api
ANALYTICS_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
ANALYTICS_SERVICE_ANALYTICS_LIVE_TTL_HOURS=48

# === NOTIFICATION SERVICE ===
NOTIFICATION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/0
NOTIFICATION_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo
NOTIFICATION_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
NOTIFICATION_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
NOTIFICATION_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
NOTIFICATION_SERVICE_ZITADEL_AUDIENCE=notification-service
NOTIFICATION_SERVICE_JWT_AUDIENCE=notification-service
NOTIFICATION_SERVICE_WS_HEARTBEAT_SECONDS=30
NOTIFICATION_SERVICE_WS_IDLE_TIMEOUT_SECONDS=120
NOTIFICATION_SERVICE_WS_REPLAY_TTL_MINUTES=5
NOTIFICATION_SERVICE_WS_MAX_CONNECTIONS_PER_USER=3

# === FRONTEND ===
FRONTEND_VITE_PUBLIC_APP_URL=http://app.cauppo.localhost
FRONTEND_VITE_API_BASE_URL=http://api.cauppo.localhost
FRONTEND_VITE_AUTH_BASE_URL=http://auth.cauppo.localhost
FRONTEND_VITE_WS_URL=ws://api.cauppo.localhost/v1/ws
FRONTEND_VITE_ANALYTICS_WS_URL=ws://api.cauppo.localhost/v1/manager/analytics/live
FRONTEND_VITE_TRACE_HEADER=x-trace-id
FRONTEND_VITE_PWA_NAME=Cauppo
FRONTEND_VITE_PWA_SHORT_NAME=Cauppo
FRONTEND_VITE_APP_ENV=development