# ============================================================
# CAUPPO — isolated-test environment (example template)
# Copy to envs/.env.test and replace placeholders with your
# local Zitadel console values before running docker compose.
# ============================================================

# === COMMON ===
CAUPPO_ENV=test
NODE_ENV=test
CAUPPO_ENV_PROVENANCE=isolated-test
CAUPPO_TEST_ENV_APPROVED=true
CAUPPO_TRACE_HEADER=x-trace-id
COMPOSE_PROJECT_NAME=cauppo-isolated-test
CAUPPO_COMPOSE_EDGE_NETWORK=cauppo-isolated-test-edge
CAUPPO_COMPOSE_INTERNAL_NETWORK=cauppo-isolated-test-internal
CAUPPO_COMPOSE_POSTGRES_VOLUME=cauppo-isolated-test-postgres-data
CAUPPO_COMPOSE_REDIS_VOLUME=cauppo-isolated-test-redis-data
CAUPPO_COMPOSE_RABBITMQ_VOLUME=cauppo-isolated-test-rabbitmq-data
CAUPPO_COMPOSE_MINIO_VOLUME=cauppo-isolated-test-minio-data
CAUPPO_HOST_PORT_POSTGRES=5432
CAUPPO_HOST_PORT_REDIS=6379
CAUPPO_HOST_PORT_RABBITMQ=5672
CAUPPO_HOST_PORT_RABBITMQ_MANAGEMENT=15672
CAUPPO_HOST_PORT_TRAEFIK_WEB=80
CAUPPO_HOST_PORT_TRAEFIK_DASHBOARD=8090
CAUPPO_HOST_PORT_ZITADEL=8080
CAUPPO_HOST_PORT_USER_SERVICE=3001
CAUPPO_HOST_PORT_FEEDBACK_SERVICE=3002
CAUPPO_HOST_PORT_MENU_SERVICE=8081
CAUPPO_HOST_PORT_ORDER_SERVICE=8082
CAUPPO_HOST_PORT_ANALYTICS_SERVICE=8083
CAUPPO_HOST_PORT_NOTIFICATION_SERVICE=8084
CAUPPO_HOST_PORT_MINIO_API=9000
CAUPPO_HOST_PORT_MINIO_CONSOLE=9001
CAUPPO_HOST_PORT_MAILPIT_SMTP=1025
CAUPPO_HOST_PORT_MAILPIT_WEB=8025
CAUPPO_HOST_PORT_FRONTEND=3000

# === POSTGRES ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === REDIS ===
REDIS_PASSWORD=cauppo_redis_test
REDIS_URL=redis://:cauppo_redis_test@redis:6379/1

# === RABBITMQ ===
RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
RABBITMQ_DEFAULT_USER=cauppo_test
RABBITMQ_DEFAULT_PASS=cauppo_test
RABBITMQ_DEFAULT_VHOST=/cauppo_test

# === ZITADEL ===
# Replace with values from your local Zitadel console setup.
ZITADEL_PROJECT_ID=test-project-id
ZITADEL_SHARED_PROJECT_ID=test-project-id
ZITADEL_SHARED_PROJECT_AUDIENCE=test-project-id
ZITADEL_SHARED_PROJECT_AUDIENCE_SCOPE=urn:zitadel:iam:org:project:id:test-project-id:aud
ZITADEL_ISSUER=http://zitadel:8080
ZITADEL_ISSUER_URL=http://zitadel:8080
ZITADEL_DOMAIN=zitadel
ZITADEL_EXTERNALPORT=80
ZITADEL_EXTERNALSECURE=false
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_DATABASE_POSTGRES_DATABASE=zitadel_test
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/zitadel_test?sslmode=disable
ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys

# === USER SERVICE ===
USER_SERVICE_PORT=3001
USER_SERVICE_DATABASE_URL=postgresql://cauppo_user:cauppo_user@postgres:5432/cauppo_users_test
USER_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
USER_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
USER_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
USER_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
USER_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
USER_SERVICE_ZITADEL_API_URL=http://auth.cauppo.localhost
USER_SERVICE_ZITADEL_INTERNAL_URL=http://zitadel:8080
USER_SERVICE_ZITADEL_AUDIENCE=test-project-id
USER_SERVICE_JWT_AUDIENCE=test-project-id
USER_SERVICE_ZITADEL_OIDC_CLIENT_ID=test-oidc-client-id
USER_SERVICE_ZITADEL_CLIENT_ID=test-api-client-id
USER_SERVICE_ZITADEL_CLIENT_SECRET=test-api-client-secret
USER_SERVICE_ZITADEL_MANAGEMENT_CLIENT_ID=test-management-client-id
USER_SERVICE_ZITADEL_MANAGEMENT_CLIENT_SECRET=test-management-client-secret
USER_SERVICE_RESEND_API_KEY=re_test_placeholder
USER_SERVICE_RESEND_FROM_EMAIL=noreply@cauppo.test
USER_SERVICE_SMTP_HOST=mailpit
USER_SERVICE_SMTP_PORT=1025
USER_SERVICE_SMTP_SECURE=false
USER_SERVICE_R2_ENDPOINT=http://minio:9000
USER_SERVICE_R2_ACCOUNT_ID=test
USER_SERVICE_R2_BUCKET_AVATARS=cauppo-avatars-test
USER_SERVICE_R2_BUCKET_RESTAURANTS=cauppo-restaurants-test
USER_SERVICE_R2_BUCKET_NAME=cauppo-assets-test
USER_SERVICE_R2_ACCESS_KEY_ID=minioadmin
USER_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin
USER_SERVICE_R2_PUBLIC_URL=http://localhost:9000/cauppo-assets-test
USER_SERVICE_KONNECT_API_KEY=test-placeholder
USER_SERVICE_KONNECT_WEBHOOK_SECRET=test-placeholder
USER_SERVICE_CAUPPO_PUBLIC_APP_URL=http://app.cauppo.localhost

# === FEEDBACK SERVICE ===
FEEDBACK_SERVICE_PORT=3002
FEEDBACK_SERVICE_DATABASE_URL=postgresql://cauppo_feedback:cauppo_feedback@postgres:5432/cauppo_feedback_test
FEEDBACK_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
FEEDBACK_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
FEEDBACK_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
FEEDBACK_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
FEEDBACK_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
FEEDBACK_SERVICE_ZITADEL_AUDIENCE=test-project-id
FEEDBACK_SERVICE_JWT_AUDIENCE=test-project-id
FEEDBACK_SERVICE_ZITADEL_CLIENT_ID=test-feedback-client-id
FEEDBACK_SERVICE_ZITADEL_CLIENT_SECRET=test-feedback-client-secret
FEEDBACK_SERVICE_ORDER_SERVICE_INTERNAL_URL=http://order-service:8082

# === MENU SERVICE ===
MENU_SERVICE_PORT=8081
MENU_SERVICE_DATABASE_URL=postgresql://cauppo_menu:cauppo_menu@postgres:5432/cauppo_menu_test
MENU_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
MENU_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
MENU_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
MENU_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
MENU_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
MENU_SERVICE_ZITADEL_AUDIENCE=test-project-id
MENU_SERVICE_JWT_AUDIENCE=test-project-id
MENU_SERVICE_ZITADEL_CLIENT_ID=test-menu-client-id
MENU_SERVICE_ZITADEL_CLIENT_SECRET=test-menu-client-secret
MENU_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
MENU_SERVICE_ORDER_SERVICE_INTERNAL_URL=http://order-service:8082
MENU_SERVICE_R2_ENDPOINT=http://minio:9000
MENU_SERVICE_R2_BUCKET_MENU_ITEMS=cauppo-menu-items-test
MENU_SERVICE_R2_BUCKET_QR=cauppo-qr-test
MENU_SERVICE_R2_ACCESS_KEY_ID=minioadmin
MENU_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin

# === ORDER SERVICE ===
ORDER_SERVICE_PORT=8082
ORDER_SERVICE_DATABASE_URL=postgresql://cauppo_order:cauppo_order@postgres:5432/cauppo_orders_test
ORDER_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
ORDER_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
ORDER_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
ORDER_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
ORDER_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
ORDER_SERVICE_ZITADEL_AUDIENCE=test-project-id
ORDER_SERVICE_JWT_AUDIENCE=test-project-id
ORDER_SERVICE_ZITADEL_CLIENT_ID=test-order-client-id
ORDER_SERVICE_ZITADEL_CLIENT_SECRET=test-order-client-secret
ORDER_SERVICE_MENU_SERVICE_INTERNAL_URL=http://menu-service:8081
ORDER_SERVICE_ORDER_IDEMPOTENCY_TTL_SECONDS=30
ORDER_SERVICE_TABLE_SESSION_LOCK_TTL_SECONDS=5

# === ANALYTICS SERVICE ===
ANALYTICS_SERVICE_PORT=8083
ANALYTICS_SERVICE_DATABASE_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics_test
ANALYTICS_SERVICE_ANALYTICS_READ_REPLICA_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics_read_test
ANALYTICS_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
ANALYTICS_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
ANALYTICS_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
ANALYTICS_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
ANALYTICS_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
ANALYTICS_SERVICE_ZITADEL_AUDIENCE=test-project-id
ANALYTICS_SERVICE_JWT_AUDIENCE=test-project-id
ANALYTICS_SERVICE_ZITADEL_CLIENT_ID=test-analytics-client-id
ANALYTICS_SERVICE_ZITADEL_CLIENT_SECRET=test-analytics-client-secret
ANALYTICS_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
ANALYTICS_SERVICE_ANALYTICS_LIVE_TTL_HOURS=1

# === NOTIFICATION SERVICE ===
NOTIFICATION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_REDIS_URL=redis://:cauppo_redis_test@redis:6379/1
NOTIFICATION_SERVICE_RABBITMQ_URL=amqp://cauppo_test:cauppo_test@rabbitmq:5672/%2Fcauppo_test
NOTIFICATION_SERVICE_ZITADEL_ISSUER=http://auth.cauppo.localhost
NOTIFICATION_SERVICE_ZITADEL_ISSUER_URL=http://auth.cauppo.localhost
NOTIFICATION_SERVICE_ZITADEL_JWKS_URL=http://auth.cauppo.localhost/oauth/v2/keys
NOTIFICATION_SERVICE_ZITADEL_AUDIENCE=test-project-id
NOTIFICATION_SERVICE_JWT_AUDIENCE=test-project-id
NOTIFICATION_SERVICE_ZITADEL_CLIENT_ID=test-notification-client-id
NOTIFICATION_SERVICE_ZITADEL_CLIENT_SECRET=test-notification-client-secret
NOTIFICATION_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
NOTIFICATION_SERVICE_WS_HEARTBEAT_SECONDS=30
NOTIFICATION_SERVICE_WS_IDLE_TIMEOUT_SECONDS=120
NOTIFICATION_SERVICE_WS_REPLAY_TTL_MINUTES=5
NOTIFICATION_SERVICE_WS_MAX_CONNECTIONS_PER_USER=20

# === MINIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === FRONTEND ===
FRONTEND_VITE_PUBLIC_APP_URL=http://app.cauppo.localhost
FRONTEND_VITE_API_BASE_URL=http://api.cauppo.localhost
FRONTEND_VITE_AUTH_BASE_URL=http://auth.cauppo.localhost
FRONTEND_VITE_WS_URL=ws://api.cauppo.localhost/v1/ws
FRONTEND_VITE_ANALYTICS_WS_URL=ws://api.cauppo.localhost/v1/manager/analytics/live
FRONTEND_VITE_ZITADEL_CLIENT_ID=test-frontend-client-id
FRONTEND_VITE_ZITADEL_PROJECT_ID=test-project-id
FRONTEND_VITE_ZITADEL_AUDIENCE=test-project-id
FRONTEND_VITE_ZITADEL_AUDIENCE_SCOPE=urn:zitadel:iam:org:project:id:test-project-id:aud
FRONTEND_VITE_TRACE_HEADER=x-trace-id
FRONTEND_VITE_PWA_NAME=Cauppo
FRONTEND_VITE_PWA_SHORT_NAME=Cauppo
FRONTEND_VITE_APP_ENV=test
