# Template for envs/.env.production
# Copy to envs/.env.production and fill in real values before running docker compose.
# This file is safe to commit - it contains only structure, no real secrets.

# === COMMON ===
CAUPPO_ENV=production
NODE_ENV=production
CAUPPO_TRACE_HEADER=x-trace-id

# === POSTGRES ===
POSTGRES_USER=REPLACE_WITH_PRODUCTION_POSTGRES_USER
POSTGRES_PASSWORD=REPLACE_WITH_PRODUCTION_POSTGRES_PASSWORD
POSTGRES_HOST=REPLACE_WITH_PRODUCTION_POSTGRES_HOST
POSTGRES_PORT=5432

# === REDIS ===
REDIS_URL=REPLACE_WITH_PRODUCTION_REDIS_URL

# === RABBITMQ ===
RABBITMQ_URL=REPLACE_WITH_PRODUCTION_RABBITMQ_URL
RABBITMQ_DEFAULT_USER=REPLACE_WITH_PRODUCTION_RABBITMQ_USER
RABBITMQ_DEFAULT_PASS=REPLACE_WITH_PRODUCTION_RABBITMQ_PASSWORD
RABBITMQ_DEFAULT_VHOST=REPLACE_WITH_PRODUCTION_RABBITMQ_VHOST

# === ZITADEL ===
ZITADEL_ISSUER=REPLACE_WITH_PRODUCTION_ZITADEL_ISSUER
ZITADEL_ISSUER_URL=REPLACE_WITH_PRODUCTION_ZITADEL_ISSUER_URL
ZITADEL_DOMAIN=REPLACE_WITH_PRODUCTION_ZITADEL_DOMAIN
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true
ZITADEL_MASTERKEY=REPLACE_WITH_PRODUCTION_ZITADEL_MASTERKEY
ZITADEL_DATABASE_POSTGRES_DSN=REPLACE_WITH_PRODUCTION_ZITADEL_DATABASE_POSTGRES_DSN
ZITADEL_JWKS_URL=REPLACE_WITH_PRODUCTION_ZITADEL_JWKS_URL

# === TRAEFIK ===
# No dedicated env keys in envs/.env.production.
# Traefik is configured via docker-compose.yml, docker-compose.infra.yml, and traefik/dynamic.yml.

# === MINIO ===
# No dedicated env keys in envs/.env.production.
# Production object storage values are supplied through the service R2 variables below.

# === MAILPIT ===
# No dedicated env keys in envs/.env.production.
# Mailpit is a local-dev dependency and is not expected in production.

# === USER SERVICE ===
