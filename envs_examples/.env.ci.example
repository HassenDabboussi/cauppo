# Template for envs/.env.ci
# Copy to envs/.env.ci and fill in real values before running docker compose.
# This file is safe to commit - it contains only structure, no real secrets.

# === COMMON ===
CAUPPO_ENV=test
NODE_ENV=test
CAUPPO_TRACE_HEADER=x-trace-id

# === POSTGRES ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === REDIS ===
REDIS_URL=redis://:cauppo_redis@redis:6379/2

# === RABBITMQ ===
RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
RABBITMQ_DEFAULT_USER=cauppo
RABBITMQ_DEFAULT_PASS=cauppo
RABBITMQ_DEFAULT_VHOST=/cauppo_ci

# === ZITADEL ===
ZITADEL_ISSUER=http://zitadel:8080
ZITADEL_ISSUER_URL=http://zitadel:8080
ZITADEL_DOMAIN=zitadel
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_MASTERKEY=CIMasterkeyNeeds32Characters!
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/zitadel_test?sslmode=disable
ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys

# === TRAEFIK ===
# No dedicated env keys in envs/.env.ci.
# Traefik is configured via docker-compose.yml, docker-compose.infra.yml, and traefik/dynamic.yml.

# === MINIO ===
# No dedicated env keys in envs/.env.ci.
# MinIO CI credentials and bucket bootstrap are configured in docker-compose.infra.yml.

# === MAILPIT ===
# No dedicated env keys in envs/.env.ci.
# Mailpit CI auth is configured in docker-compose.infra.yml.

# === USER SERVICE ===
USER_SERVICE_PORT=3001
USER_SERVICE_DATABASE_URL=postgresql://cauppo_user:cauppo_user@postgres:5432/cauppo_users_test
USER_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
USER_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
USER_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
USER_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
USER_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
USER_SERVICE_ZITADEL_AUDIENCE=user-service
USER_SERVICE_JWT_AUDIENCE=user-service
USER_SERVICE_ZITADEL_CLIENT_ID=ci-user-service-client
USER_SERVICE_ZITADEL_CLIENT_SECRET=ci-secret
USER_SERVICE_RESEND_API_KEY=re_ci_placeholder
USER_SERVICE_RESEND_FROM_EMAIL=noreply@ci.cauppo.local
USER_SERVICE_R2_ENDPOINT=http://minio:9000
USER_SERVICE_R2_ACCOUNT_ID=ci
USER_SERVICE_R2_BUCKET_AVATARS=cauppo-avatars-test
USER_SERVICE_R2_BUCKET_RESTAURANTS=cauppo-restaurants-test
USER_SERVICE_R2_BUCKET_NAME=cauppo-assets-test
USER_SERVICE_R2_ACCESS_KEY_ID=minioadmin
USER_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin
USER_SERVICE_R2_PUBLIC_URL=http://minio:9000/cauppo-assets-test
USER_SERVICE_SMTP_HOST=mailpit
USER_SERVICE_SMTP_PORT=1025
USER_SERVICE_SMTP_SECURE=false
USER_SERVICE_KONNECT_API_KEY=ci-placeholder
USER_SERVICE_KONNECT_WEBHOOK_SECRET=ci-placeholder
USER_SERVICE_CAUPPO_PUBLIC_APP_URL=http://frontend:5173

# === FEEDBACK SERVICE ===
FEEDBACK_SERVICE_PORT=3002
FEEDBACK_SERVICE_DATABASE_URL=postgresql://cauppo_feedback:cauppo_feedback@postgres:5432/cauppo_feedback_test
FEEDBACK_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
