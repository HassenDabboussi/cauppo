MENU_SERVICE_R2_ACCESS_KEY_ID=minioadmin
MENU_SERVICE_R2_SECRET_ACCESS_KEY=minioadmin

# === ORDER SERVICE ===
ORDER_SERVICE_PORT=8082
ORDER_SERVICE_DATABASE_URL=postgresql://cauppo_order:cauppo_order@postgres:5432/cauppo_orders_test
ORDER_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
ORDER_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
ORDER_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
ORDER_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
ORDER_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
ORDER_SERVICE_ZITADEL_AUDIENCE=order-service
ORDER_SERVICE_JWT_AUDIENCE=order-service
ORDER_SERVICE_MENU_SERVICE_INTERNAL_URL=http://menu-service:8081
ORDER_SERVICE_ORDER_IDEMPOTENCY_TTL_SECONDS=300
ORDER_SERVICE_TABLE_SESSION_LOCK_TTL_SECONDS=30

# === ANALYTICS SERVICE ===
ANALYTICS_SERVICE_PORT=8083
ANALYTICS_SERVICE_DATABASE_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics_test
ANALYTICS_SERVICE_ANALYTICS_READ_REPLICA_URL=postgresql://cauppo_analytics:cauppo_analytics@postgres:5432/cauppo_analytics_read_test
ANALYTICS_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
ANALYTICS_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
ANALYTICS_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
ANALYTICS_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
ANALYTICS_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
ANALYTICS_SERVICE_ZITADEL_AUDIENCE=cauppo-api
ANALYTICS_SERVICE_JWT_AUDIENCE=cauppo-api
ANALYTICS_SERVICE_USER_SERVICE_INTERNAL_URL=http://user-service:3001
ANALYTICS_SERVICE_ANALYTICS_LIVE_TTL_HOURS=48

# === NOTIFICATION SERVICE ===
NOTIFICATION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
NOTIFICATION_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
NOTIFICATION_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
NOTIFICATION_SERVICE_ZITADEL_ISSUER_URL=http://zitadel:8080
NOTIFICATION_SERVICE_ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
NOTIFICATION_SERVICE_ZITADEL_AUDIENCE=notification-service
NOTIFICATION_SERVICE_JWT_AUDIENCE=notification-service
NOTIFICATION_SERVICE_WS_HEARTBEAT_SECONDS=30
NOTIFICATION_SERVICE_WS_IDLE_TIMEOUT_SECONDS=120
NOTIFICATION_SERVICE_WS_REPLAY_TTL_MINUTES=5
NOTIFICATION_SERVICE_WS_MAX_CONNECTIONS_PER_USER=3

# === FRONTEND ===
FRONTEND_VITE_PUBLIC_APP_URL=http://frontend:5173
FRONTEND_VITE_API_BASE_URL=http://traefik
FRONTEND_VITE_AUTH_BASE_URL=http://zitadel:8080
FRONTEND_VITE_WS_URL=ws://notification-service:8084/v1/ws
FRONTEND_VITE_ANALYTICS_WS_URL=ws://analytics-service:8083/v1/manager/analytics/live
FRONTEND_VITE_TRACE_HEADER=x-trace-id
FRONTEND_VITE_PWA_NAME=Cauppo CI
FRONTEND_VITE_PWA_SHORT_NAME=CauppoCI
FRONTEND_VITE_APP_ENV=test