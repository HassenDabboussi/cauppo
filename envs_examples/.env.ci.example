FEEDBACK_SERVICE_ZITADEL_CLIENT_ID=ci-feedback-client
FEEDBACK_SERVICE_ORDER_SERVICE_INTERNAL_URL=http://order-service:8082

# === MENU SERVICE ===
MENU_SERVICE_PORT=8081
MENU_SERVICE_DATABASE_URL=postgresql://cauppo_menu:cauppo_menu@postgres:5432/cauppo_menu_test
MENU_SERVICE_REDIS_URL=redis://:cauppo_redis@redis:6379/2
MENU_SERVICE_RABBITMQ_URL=amqp://cauppo:cauppo@rabbitmq:5672/%2Fcauppo_ci
MENU_SERVICE_ZITADEL_ISSUER=http://zitadel:8080
